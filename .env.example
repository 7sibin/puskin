# ══════════════════════════════════════
# ZLATAR STARS — Environment Variables
# Kopirajte u .env i popunite vrednosti
# ══════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Email (Gmail SMTP — koristite App Password)
EMAIL_USER=info@zlatarstars.rs
EMAIL_PASS=vaš-app-password

# Admin
ADMIN_TOKEN=promenite-ovo-u-dugacak-random-string

# Frontend URL (za CORS)
FRONTEND_URL=https://www.zlatarstars.rs
